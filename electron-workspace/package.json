{
  "name": "intern-rotation-electron",
  "version": "1.0.0-win7",
  "description": "Win7 legacy flavor of Intern Rotation System. Built with Electron 22.x (the last Electron line that supports Windows 7 SP1). Pre-release alpha: backend services are stubs.",
  "private": true,
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "pack": "electron-builder --dir",
    "dist:win7": "electron-builder --win nsis portable --x64 --publish never",
    "postinstall": "electron-builder install-app-deps || echo 'install-app-deps skipped'"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "electron": "^22.3.27",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.intern-rotation.system.win7",
    "productName": "实习生管理系统 Win7",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "preload.js",
      "lib/**/*",
      "renderer/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ],
      "artifactName": "${productName}_v${version}_${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "实习生管理系统"
    },
    "portable": {
      "artifactName": "${productName}_v${version}_${arch}_portable.${ext}"
    }
  }
}
