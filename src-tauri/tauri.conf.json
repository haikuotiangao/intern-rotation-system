{
  "$schema": "https://raw.githubusercontent.com/nicedayzhu/tauri-v2-schema/main/tauri.conf.schema.json",
  "productName": "实习生管理系统",
  "version": "1.0.0",
  "identifier": "com.intern-rotation.system",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "title": "实习生管理系统",
        "width": 1400,
        "height": 900,
        "resizable": true,
        "fullscreen": false,
        "minWidth": 1200,
        "minHeight": 800,
        "devtools": true,
        "label": "main"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "deb", "appimage"],
    "icon": [
      "icons/icon.ico",
      "icons/icon.png",
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns"
    ],
    "windows": {
      "nsis": {
        "installerHooks": "nsis-hooks/installer-custom.nsh",
        "displayLanguageSelector": false
      }
    },
    "linux": {
      "deb": {
        "depends": []
      }
    }
  }
}
